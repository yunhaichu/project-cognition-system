  "properties": {
    "state_schema_version": {"type": "string"},
    "upgraded_at": {"type": "string"},
    "from_version": {"type": "string"},
    "upgrade_rules": {"type": "array", "items": {"type": "string"}},
    "local_only": {"type": "boolean"},
    "llm_used": {"type": "boolean"}
  }
}
