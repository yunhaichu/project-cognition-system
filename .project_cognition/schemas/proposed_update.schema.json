{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ProposedUpdate",
  "type": "object",
  "required": ["id", "timestamp", "claim", "category", "evidence", "confidence", "reason", "conflicts", "suggested_action", "should_update_world_state", "status"],
  "properties": {
    "id": {"type": "string"},
    "timestamp": {"type": "string"},
    "claim": {"type": "string"},
    "category": {"type": "string", "enum": ["user_principle", "project_principle", "constraint", "risk", "strategy", "decision"]},
    "evidence": {"type": "array", "items": {"type": "string"}},
    "confidence": {"type": "integer", "minimum": 0, "maximum": 100},
    "reason": {"type": "string"},
    "conflicts": {"type": "array", "items": {"type": "string"}},
    "suggested_action": {"type": "string", "enum": ["accept", "reject", "defer"]},
    "should_update_world_state": {"type": "boolean"},
    "status": {"type": "string", "enum": ["pending", "accepted", "rejected", "deferred"]},
    "structured": {
      "type": "object",
      "properties": {
        "subject": {"type": "string"},
        "predicate": {
          "type": "string",
          "enum": [
            "states",
            "requires",
            "observed",
            "infers",
            "enter_core_memory",
            "store_log",
            "create",
            "render",
            "override",
            "require_review",
            "inject_context",
            "call_llm",
            "read_source",
            "update_world_state",
            "score_evidence",
            "resolve_conflict",
            "test_passed"
          ]
        },
        "object": {"type": "string"},
        "scope": {"type": "string"},
        "modality": {"type": "string", "enum": ["must", "should", "may", "must_not", "is", "is_not", "unknown"]},
        "valid_from": {"type": "string"},
        "valid_until": {"type": ["string", "null"]},
        "source_refs": {"type": "array", "items": {"type": "string"}},
        "confidence_reason": {"type": "string"},
        "supersedes": {"type": "array", "items": {"type": "string"}}
      }
    }
  }
}
