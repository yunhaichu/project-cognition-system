{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "CognitionCandidate",
  "type": "object",
  "required": ["id", "claim", "category", "confidence", "evidence", "conflicts", "last_verified", "stability", "include_in_world_state"],
  "properties": {
    "id": {"type": "string"},
    "claim": {"type": "string"},
    "category": {"type": "string", "enum": ["user_principle", "project_principle", "constraint", "risk", "strategy", "decision"]},
    "confidence": {"type": "integer", "minimum": 0, "maximum": 100},
    "evidence": {"type": "array", "items": {"type": "string"}},
    "conflicts": {"type": "array", "items": {"type": "string"}},
    "last_verified": {"type": "string"},
    "stability": {"type": "string", "enum": ["stable", "evolving", "temporary"]},
    "include_in_world_state": {"type": "boolean"},
    "source_type": {"type": "string"},
    "status": {"type": "string"},
    "score_signals": {"type": "array", "items": {"type": "string"}},
    "evidence_types": {"type": "array", "items": {"type": "string"}},
    "requires_review_for_world_state": {"type": "boolean"},
    "requires_governance_gate_for_world_state": {"type": "boolean"},
    "structured": {
      "type": "object",
      "properties": {
        "subject": {"type": "string"},
        "predicate": {
          "type": "string",
          "enum": [
            "states",
            "requires",
            "observed",
            "infers",
            "enter_core_memory",
            "store_log",
            "create",
            "render",
            "override",
            "require_review",
            "inject_context",
            "call_llm",
            "read_source",
            "update_world_state",
            "score_evidence",
            "resolve_conflict",
            "test_passed"
          ]
        },
        "object": {"type": "string"},
        "object_key": {"type": "string"},
        "scope": {"type": "string"},
        "modality": {"type": "string", "enum": ["must", "should", "may", "must_not", "is", "is_not", "unknown"]},
        "valid_from": {"type": "string"},
        "valid_until": {"type": ["string", "null"]},
        "source_refs": {"type": "array", "items": {"type": "string"}},
        "confidence_reason": {"type": "string"},
        "supersedes": {"type": "array", "items": {"type": "string"}}
      }
    },
    "superseded_by": {"type": "string"}
  }
}
