{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ContextInjection",
  "type": "object",
  "required": ["id", "session_id", "timestamp", "max_chars", "included_cognition_ids", "excluded_reason_counts", "prompt_fingerprint", "ruleset_hash", "output_characters", "mutates_state"],
  "properties": {
    "id": {"type": "string"},
    "session_id": {"type": "string"},
    "timestamp": {"type": "string"},
    "task": {"type": "string"},
    "max_chars": {"type": "integer", "minimum": 0},
    "included_cognition_ids": {"type": "array", "items": {"type": "string"}},
    "excluded_reason_counts": {"type": "object"},
    "prompt_fingerprint": {"type": "string"},
    "ruleset_hash": {"type": "string"},
    "gate_policy_hash": {"type": "string"},
    "source_manifest": {"type": "object"},
    "output_characters": {"type": "integer", "minimum": 0},
    "mutates_state": {"type": "boolean"}
  }
}
